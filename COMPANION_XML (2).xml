<!-- ╔═══════════════════════════════════════════════════════╗ -->
<!-- ║  GOLDEN RULE — IDs that match the Kotlin cheatsheet  ║ -->
<!-- ║  EditText   → etName, etPhone, etEmail, etInput      ║ -->
<!-- ║  Button     → btnSubmit, btnBack, btnReset, btnPick  ║ -->
<!-- ║  TextView   → tvResult, tvDate, tvTime, tvSelected   ║ -->
<!-- ║  Spinner    → spinner, spinnerService, spinnerType   ║ -->
<!-- ║  ListView   → listView                               ║ -->
<!-- ║  GridView   → gridView                               ║ -->
<!-- ║  ToggleBtn  → toggleBtn                              ║ -->
<!-- ║  CheckBox   → cbItem1, cbItem2, cbItem3              ║ -->
<!-- ╚═══════════════════════════════════════════════════════╝ -->


